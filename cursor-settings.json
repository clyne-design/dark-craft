    "editor.semanticHighlighting.enabled": true,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "constant.language.boolean",
                    "constant.language.boolean.true.json",
                    "constant.language.boolean.false.json",
                    "constant.language.null",
                    "constant.language.null.json",
                    "constant.language.undefined"
                ],
                "settings": {
                    "foreground": "#78aff9"
                }
            },
            {
                "scope": [
                    "support.type.property-name.json",
                    "punctuation.support.type.property-name.begin.json",
                    "punctuation.support.type.property-name.end.json"
                ],
                "settings": {
                    "foreground": "#c089bc"
                }
            },
            {
                "scope": [
                    "comment",
                    "punctuation.definition.comment"
                ],
                "settings": {
                    "foreground": "#7A7E85"
                }
            },
            {
                "scope": [
                    "keyword",
                    "storage",
                    "storage.type",
                    "keyword.control",
                    "keyword.operator.expression",
                    "keyword.control.import",
                    "keyword.control.from",
                    "punctuation.definition.keyword.scss",
                    "punctuation.definition.keyword.css",
                    "punctuation.definition.keyword.less"
                ],
                "settings": {
                    "foreground": "#66B1FF"
                }
            },
            {
                "scope": [
                    "string",
                    "string.quoted"
                ],
                "settings": {
                    "foreground": "#ECDB87"
                }
            },
            {
                "scope": [
                    "constant.numeric"
                ],
                "settings": {
                    "foreground": "#B48AE3"
                }
            },
            {
                "scope": [
                    "variable",
                    "meta.object-literal.key",
                    "support.variable"
                ],
                "settings": {
                    "foreground": "#C1C7DD"
                }
            },
            {
                "scope": [
                    "variable.parameter",
                    "meta.parameter",
                    "meta.destructuring variable"
                ],
                "settings": {
                    "foreground": "#E19C2F"
                }
            },
            {
                "scope": [
                    "entity.name.function",
                    "support.function",
                    "meta.function-call",
                    "variable.function",
                    "entity.name.function.js"
                ],
                "settings": {
                    "foreground": "#b4ec91"
                }
            },
            {
                "scope": [
                    "entity.name.type",
                    "entity.name.class",
                    "support.class",
                    "support.type",
                    "entity.name.type.class"
                ],
                "settings": {
                    "foreground": "#7adeb0"
                }
            },
            {
                "scope": [
                    "entity.name.tag"
                ],
                "settings": {
                    "foreground": "#E14C61"
                }
            },
            {
                "scope": [
                    "entity.other.attribute-name"
                ],
                "settings": {
                    "foreground": "#A4EE85"
                }
            },
            {
                "scope": [
                    "variable.other.property",
                    "variable.object.property",
                    "meta.property-name",
                    "meta.member.access"
                ],
                "settings": {
                    "foreground": "#C1C7DD"
                }
            },
            {
                "scope": [
                    "punctuation",
                    "meta.brace",
                    "meta.delimiter"
                ],
                "settings": {
                    "foreground": "#BCBEC4"
                }
            },
            {
                "scope": [
                    "meta.separator",
                    "punctuation.separator",
                    "punctuation.accessor"
                ],
                "settings": {
                    "foreground": "#E39D37"
                }
            },
            {
                "scope": [
                    "invalid"
                ],
                "settings": {
                    "foreground": "#F75464"
                }
            },
            {
                "scope": [
                    "regexp"
                ],
                "settings": {
                    "foreground": "#CEB778"
                }
            },
            {
                "scope": [
                    "string.escape"
                ],
                "settings": {
                    "foreground": "#CF8E6D"
                }
            },
            {
                "scope": [
                    "meta.import entity.name.tag",
                    "meta.import.ts entity.name.tag",
                    "meta.import.js entity.name.tag",
                    "meta.import.jsx entity.name.tag",
                    "variable.other.readwrite.alias",
                    "variable.other.readwrite.alias.ts",
                    "variable.other.readwrite.alias.js"
                ],
                "settings": {
                    "foreground": "#A4EE85"
                }
            },
            {
                "scope": [
                    "support.type.property-name.css",
                    "support.type.property-name.scss",
                    "support.type.property-name.less"
                ],
                "settings": {
                    "foreground": "#C6C6DC"
                }
            },
            {
                "scope": [
                    "support.constant.property-value.css",
                    "support.constant.property-value.scss",
                    "support.constant.property-value.less",
                    "support.constant.font-name.css",
                    "support.constant.media-type.css",
                    "support.constant.media-type.scss"
                ],
                "settings": {
                    "foreground": "#7BC65A"
                }
            },
            {
                "scope": [
                    "entity.name.tag.css",
                    "entity.name.tag.scss",
                    "entity.name.tag.less"
                ],
                "settings": {
                    "foreground": "#E14C61"
                }
            },
            {
                "scope": [
                    "entity.other.attribute-name.id.css",
                    "entity.other.attribute-name.id.scss"
                ],
                "settings": {
                    "foreground": "#7adeb0"
                }
            },
            {
                "scope": [
                    "entity.other.attribute-name.class.css",
                    "entity.other.attribute-name.class.scss"
                ],
                "settings": {
                    "foreground": "#A4EE85"
                }
            },
            {
                "scope": [
                    "variable.scss",
                    "variable.sass",
                    "variable.other.sass",
                    "variable.other.scss",
                    "variable.other.less"
                ],
                "settings": {
                    "foreground": "#C6C6DC"
                }
            },
            {
                "scope": [
                    "entity.name.function.scss",
                    "entity.name.function.less",
                    "support.function.misc.css",
                    "support.function.scss"
                ],
                "settings": {
                    "foreground": "#A4EE85"
